{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "http://localhost:54321/mcp",
      "autoApprove": [
        "list_tables",
        "describe_table",
        "execute_sql",
        "get_project_config",
        "apply_migration"
      ],
      "disabled": false
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "disabled": true
    }
  }
}