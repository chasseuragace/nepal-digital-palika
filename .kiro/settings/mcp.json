{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "http://localhost:54321/mcp",
      "autoApprove": [
        "list_tables",
        "describe_table",
        "execute_sql",
        "get_project_config",
        "apply_migration",
        "get_logs",
        "search_docs"
      ],
      "disabled": false
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "disabled": false,
      "autoApprove": [
        "browser_click",
        "browser_network_requests",
        "browser_fill_form",
        "browser_navigate",
        "browser_wait_for",
        "browser_console_messages",
        "browser_snapshot",
        "browser_run_code",
        "browser_evaluate",
        "browser_take_screenshot",
        "browser_type",
        "browser_navigate"
      ]
    }
  }
}