# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Feature Flags ───

# Use fake datasources instead of Supabase for development
# Set to "true" to use mock data without needing Supabase running
# Applies to: Notifications, Business Targeting, etc.
NEXT_PUBLIC_USE_FAKE_DATASOURCES=true

# ─── Development ───

# Next.js environment
NODE_ENV=development
