# Netlify site config — platform-admin-panel
#
# Used by ../deploy-to-netlify.sh. See that script's header for usage.

NETLIFY_SITE_SLUG=digital-nep-platform-admin
PROJECT_DIR=platform-admin-panel

# Source of truth for NEXT_PUBLIC_SUPABASE_URL / ANON / SERVICE_ROLE.
SUPABASE_ENV_FILE=supabase/prod/.env

# Additional Next public flags that are app-specific.
EXTRA_ENV_NEXT_PUBLIC_USE_FAKE_DATASOURCES=false
EXTRA_ENV_NEXT_PUBLIC_USE_MOCK_AUTH=false
