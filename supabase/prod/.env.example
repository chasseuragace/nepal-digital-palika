# Copy to .env and fill in. .env is gitignored (see supabase/prod/.gitignore).
#
# Generate secrets with:
#   POSTGRES_PASSWORD   — openssl rand -base64 32
#   JWT_SECRET          — openssl rand -base64 48   (min 32 chars)
#   ANON_KEY / SERVICE_ROLE_KEY — see DEPLOY.md step 3 (signed JWTs derived
#                                 from JWT_SECRET; can be generated on
#                                 https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#                                 or with scripts/gen-keys.sh)

############
# Database
############
POSTGRES_PASSWORD=REPLACE_ME_strong_db_password
POSTGRES_DB=postgres

############
# JWT + API keys
############
JWT_SECRET=REPLACE_ME_min_32_char_secret
JWT_EXPIRY=3600
ANON_KEY=REPLACE_ME_signed_jwt_role_anon
SERVICE_ROLE_KEY=REPLACE_ME_signed_jwt_role_service_role

############
# URLs — path-prefix topology
############
# Where Kong is reachable from the outside world. Nginx strips the
# /tourism-supabase prefix before proxying, so Kong itself sees requests
# at root. Auth emails and storage signed URLs use this value, so it
# MUST be the full public URL including the prefix.
API_EXTERNAL_URL=https://dev.kaha.com.np/tourism-supabase

# Netlify frontend URL — used for auth email redirects.
SITE_URL=https://REPLACE_ME.netlify.app
# Comma-separated list of additional redirect URLs GoTrue should allow
# (e.g. branch previews, localhost for dev).
ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://localhost:5173

############
# Kong gateway
############
KONG_HTTP_PORT=8010

############
# Auth behaviour
############
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false

############
# SMTP (required if ENABLE_EMAIL_AUTOCONFIRM=false)
############
SMTP_ADMIN_EMAIL=admin@REPLACE_ME
SMTP_HOST=REPLACE_ME
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_SENDER_NAME=Nepal Digital Tourism

############
# Storage
############
STORAGE_FILE_SIZE_LIMIT=52428800
IMGPROXY_ENABLE_WEBP_DETECTION=true

############
# PostgREST schemas exposed via /rest/v1
############
PGRST_DB_SCHEMAS=public,storage,graphql_public
