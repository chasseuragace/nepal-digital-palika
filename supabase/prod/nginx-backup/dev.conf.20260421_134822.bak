    # Bus Payment Service — payment pages + gateway callbacks
    location /bus-payment/ {
        proxy_pass http://localhost:4001/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        error_log /var/log/nginx/proxy_error_bus_payment.log;
        access_log /var/log/nginx/proxy_access_bus_payment.log;
    }
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/dev.kaha.com.np/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/dev.kaha.com.np/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = www.dev.kaha.com.np) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = dev.kaha.com.np) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    server_name dev.kaha.com.np www.dev.kaha.com.np;
    listen 80;
    return 404; # managed by Certbot
}
